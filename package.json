{
  "name": "purchaseorder",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@sap/cds": "^9",
    "express": "^4",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.29"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-visionelectronicpurchaseorder": "cds watch --open visionelectronicpurchaseorder/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy purchaseorder --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": {
        "kind": "mocked",
        "users": {
          "admin": {
            "password": "admin",
            "roles": [
              "PurchaseorderAdmin"
            ]
          },
          "viewer": {
            "password": "viewer",
            "roles": [
              "Purchaseorderviewer"
            ]
          }
        }
      },
      "Z_PURCHASE_ORDER_SERVICE": {
        "kind": "odata",
        "model": "srv/external/Z_PURCHASE_ORDER_SERVICE",
        "credentials": {
          "destination": "s4h-dest",
          "path": "/sap/opu/odata4/iwbep/all/srvd_a2x/sap/z_purchase_order_service/0001/"
        },
        "csrf": true,
        "csrfInBatch": true,
        "[production]": {
          "credentials": {
            "destination": "s4h-dest",
            "path": "/sap/opu/odata4/iwbep/all/srvd_a2x/sap/z_purchase_order_service/0001/"
          }
        }
      },
      "[production]": {
        "auth": "xsuaa"
      }
    }
  },
  "workspaces": [
    "app/*"
  ]
}